# Proxy, if you need it
# HTTP_PROXY=http://localhost:7890
# HTTPS_PROXY=http://localhost:7890

# Allowed email addresses for login, separated by commas
# When set, only emails in the list can log in, other users cannot log in
# Leave empty to allow all users to register
# AUTH_ALLOWED_EMAILS=user1@example.com,user2@example.com

# Disable user registration (SSO-only mode)
# When set to 1, users cannot register via email/password, only SSO login is allowed
# AUTH_DISABLE_EMAIL_PASSWORD=1

# ===========================
# ====== Preset config ======
# ===========================
# if no special requirements, no need to change
LOBE_PORT=3210
APP_URL=http://localhost:3210
# Enable request-host based auth redirects and dev asset URLs.
# Use * for internal/LAN validation, or a comma-separated allowlist for production.
APP_URL_DYNAMIC=1
APP_URL_ALLOWED_HOSTS=*
# INTERNAL_APP_URL is used for internal server-to-server communication.
# Required for Docker Compose deployments, otherwise features like
# AI image generation will fail when APP_URL is a host/LAN IP.
INTERNAL_APP_URL=http://localhost:3210

# Secrets (auto-generated by setup.sh)
KEY_VAULTS_SECRET=YOUR_KEY_VAULTS_SECRET
AUTH_SECRET=YOUR_AUTH_SECRET

# Postgres related, which are the necessary environment variables for DB
DATABASE_DRIVER=node
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=uWNZugjBqixf8dxC

# Cloud object storage configuration (S3-compatible)
# Choose exactly one provider endpoint and keep the bucket private.
# Browser uploads use MasterLion's same-origin /api/upload/s3-proxy path,
# so S3_PUBLIC_UPLOAD_ENDPOINT is not required by default.
#
# Alibaba Cloud OSS example:
# S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
# S3_REGION=cn-hangzhou
#
# Tencent Cloud COS example:
# S3_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
# S3_REGION=ap-shanghai
S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou
S3_BUCKET=YOUR_OBJECT_STORAGE_BUCKET
S3_ACCESS_KEY_ID=YOUR_OBJECT_STORAGE_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_OBJECT_STORAGE_SECRET_ACCESS_KEY
S3_ENABLE_PATH_STYLE=0
S3_SET_ACL=0

# Optional RustFS diagnostic override for storage A/B testing.
# It does not migrate old COS/OSS objects; use it only for new test uploads.
# docker compose --env-file .env -f docker-compose.yml -f docker-compose.rustfs.yml up -d
# RUSTFS_BUCKET=masterlion-diagnostic
# RUSTFS_ACCESS_KEY_ID=masterlion-diagnostic
# RUSTFS_SECRET_ACCESS_KEY=change-this-diagnostic-secret

# File analysis / knowledge-base vectorization
# Use the embedding model id that Aihub exposes to the managed token/user group.
# COS/RustFS only store files; they do not provide parsing, chunking, or embeddings.
DEFAULT_FILES_CONFIG=embedding_model=newapi/YOUR_AIHUB_EMBEDDING_MODEL,query_mode=full_text
CHUNKS_AUTO_EMBEDDING=1

# Aihub integration
AIHUB_PROXY_URL=https://aihub.bielcrystal.com
AIHUB_DEFAULT_MODEL=glm-5.2
AIHUB_HIDDEN_MODELS=glm-5.1
AIHUB_MANAGED_TOKEN_NAME=masterlion-managed
AIHUB_USAGE_PAGE_SIZE=100
AIHUB_DATA_SOURCE=bridge
AIHUB_BRIDGE_URL=http://aihub-db-bridge:3218
AIHUB_BRIDGE_TOKEN=change-this-long-random-service-token
# Only aihub-db-bridge receives this DSN in docker-compose.
AIHUB_READONLY_DATABASE_URL=mysql://readonly:password@aihub-mysql:3306/newapi
AIHUB_QUERY_TIMEOUT_MS=15000
# Optional: only used when AIHUB_DATA_SOURCE is api or hybrid.
# AIHUB_ADMIN_USER_ID=1
# AIHUB_ADMIN_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generate a deployment-specific value with:
# node scripts/generate-oidc-jwk.mjs
JWKS_KEY=PASTE_GENERATED_JWKS_JSON_HERE
