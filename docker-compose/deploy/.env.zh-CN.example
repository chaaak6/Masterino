# Proxy，如果你需要的话（比如你使用 GitHub 作为鉴权服务提供商）
# HTTP_PROXY=http://localhost:7890
# HTTPS_PROXY=http://localhost:7890

# 允许登录的邮箱地址，用英文逗号分隔
# 设置后只有列表中的邮箱可以登录，其他用户可以注册但无法登录
# 留空则允许所有用户注册登录
# AUTH_ALLOWED_EMAILS=user1@example.com,user2@example.com

# 禁用用户注册（仅允许 SSO 登录）
# 设置为 1 后，用户无法通过邮箱密码注册，只能通过 SSO 登录
# AUTH_DISABLE_EMAIL_PASSWORD=1

# ===================
# ===== 预设配置 =====
# ===================
# 如没有特殊需要不用更改
LOBE_PORT=3210
APP_URL=http://localhost:3210
# 内部应用URL，用于容器内部服务间通信
# Docker Compose 部署时必须配置，否则当 APP_URL 为宿主机 IP 时 AI 生图等功能会失败
INTERNAL_APP_URL=http://localhost:3210

# 密钥配置（由 setup.sh 自动生成）
KEY_VAULTS_SECRET=YOUR_KEY_VAULTS_SECRET
AUTH_SECRET=YOUR_AUTH_SECRET

# PostgreSQL 配置
DATABASE_DRIVER=node
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=uWNZugjBqixf8dxC

# 云对象存储配置（兼容 S3）
# 选择一个对象存储 endpoint，并保持 bucket 私有。
# 浏览器上传走 MasterLion 同源 /api/upload/s3-proxy，默认不需要 S3_PUBLIC_UPLOAD_ENDPOINT。
#
# 阿里云 OSS 示例：
# S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
# S3_REGION=cn-hangzhou
#
# 腾讯云 COS 示例：
# S3_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
# S3_REGION=ap-shanghai
S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou
S3_BUCKET=YOUR_OBJECT_STORAGE_BUCKET
S3_ACCESS_KEY_ID=YOUR_OBJECT_STORAGE_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_OBJECT_STORAGE_SECRET_ACCESS_KEY
S3_ENABLE_PATH_STYLE=0
S3_SET_ACL=0

# 可选 RustFS 诊断 override，用于对象存储 A/B 测试。
# 它不会迁移旧 COS/OSS 对象，仅用于新上传测试。
# docker compose --env-file .env -f docker-compose.yml -f docker-compose.rustfs.yml up -d
# RUSTFS_BUCKET=masterlion-diagnostic
# RUSTFS_ACCESS_KEY_ID=masterlion-diagnostic
# RUSTFS_SECRET_ACCESS_KEY=change-this-diagnostic-secret

# 文件分析 / 知识库向量化
# 使用 Aihub 已授权给托管 token / 用户组的 embedding 模型 ID。
# COS/RustFS 只负责存储文件，不提供解析、分块或向量化。
DEFAULT_FILES_CONFIG=embedding_model=newapi/YOUR_AIHUB_EMBEDDING_MODEL,query_mode=full_text
CHUNKS_AUTO_EMBEDDING=1

# Aihub integration
AIHUB_PROXY_URL=https://aihub.bielcrystal.com
AIHUB_DEFAULT_MODEL=glm-5.2
AIHUB_HIDDEN_MODELS=glm-5.1
AIHUB_MANAGED_TOKEN_NAME=masterlion-managed
AIHUB_USAGE_PAGE_SIZE=100
AIHUB_DATA_SOURCE=bridge
AIHUB_BRIDGE_URL=http://aihub-db-bridge:3218
AIHUB_BRIDGE_TOKEN=change-this-long-random-service-token
# Only aihub-db-bridge receives this DSN in docker-compose.
AIHUB_READONLY_DATABASE_URL=mysql://readonly:password@aihub-mysql:3306/newapi
AIHUB_QUERY_TIMEOUT_MS=15000
# Optional: only used when AIHUB_DATA_SOURCE is api or hybrid.
# AIHUB_ADMIN_USER_ID=1
# AIHUB_ADMIN_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

