# Copy this file to secret.env and replace every CHANGE_ME value.
# secret.env is gitignored. Never commit the populated file.
# Preserve these three values exactly from the old test server.
KEY_VAULTS_SECRET=CHANGE_ME_PRESERVE_FROM_OLD_TEST
AUTH_SECRET=CHANGE_ME_PRESERVE_FROM_OLD_TEST
JWKS_KEY=CHANGE_ME_PRESERVE_FROM_OLD_TEST
# Optional. Remove the leading '#' and set at least 32 random characters only
# when a server-side Market client is configured with the same secret.
# OIDC_MARKET_CLIENT_SECRET=<at-least-32-random-characters>

# PostgreSQL and Redis credentials used by the in-cluster services.
POSTGRES_PASSWORD=CHANGE_ME_URL_SAFE_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_ME_URL_ENCODED_PASSWORD@masterino-postgres:5432/lobechat
REDIS_PASSWORD=CHANGE_ME_URL_SAFE_PASSWORD
REDIS_URL=redis://:CHANGE_ME_URL_ENCODED_PASSWORD@masterino-redis:6379/0

# Dedicated test OSS credentials. S3_ACCESS_KEY and S3_ACCESS_KEY_ID must match.
S3_ACCESS_KEY=CHANGE_ME
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME

# The application needs the shared token to authenticate calls to the bridge.
AIHUB_BRIDGE_TOKEN=CHANGE_ME_PRESERVE_FROM_OLD_TEST

# Dedicated test Upstash Workflow/QStash credentials. Never reuse production keys.
QSTASH_TOKEN=CHANGE_ME
QSTASH_CURRENT_SIGNING_KEY=CHANGE_ME
QSTASH_NEXT_SIGNING_KEY=CHANGE_ME

# SSO settings. Web search is disabled by default in the test ConfigMap.
AUTH_SSO_PROVIDERS=wecom
