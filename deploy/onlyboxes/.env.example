# Copy to /etc/masterino/onlyboxes-console.env, replace every CHANGE_ME value,
# then chmod 600. Never store the populated file in this repository.
ONLYBOXES_CONSOLE_IMAGE=boen-registry-vpc.cn-shenzhen.cr.aliyuncs.com/biel_client/onlyboxes:0.7.1
ONLYBOXES_DATA_DIR=/var/lib/onlyboxes/console

CONSOLE_HASH_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
CONSOLE_DASHBOARD_USERNAME=masterino-admin
CONSOLE_DASHBOARD_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
CONSOLE_JIT_SIGNING_KEY=CHANGE_ME_SAME_VALUE_AS_K8S_ONLYBOXES_JIT_SIGNING_KEY
