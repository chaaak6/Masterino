[Unit]
Description=Masterion Onlyboxes Console
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/onlyboxes
ExecStart=/usr/bin/docker compose --env-file /etc/masterlion/onlyboxes-console.env up -d --remove-orphans
ExecStop=/usr/bin/docker compose --env-file /etc/masterlion/onlyboxes-console.env down
TimeoutStartSec=120s
TimeoutStopSec=60s

[Install]
WantedBy=multi-user.target
