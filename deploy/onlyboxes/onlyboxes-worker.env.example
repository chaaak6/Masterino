# Copy to /etc/masterlion/onlyboxes-worker.env and chmod 600.
# WORKER_ID and WORKER_SECRET are issued once by the Onlyboxes dashboard.
WORKER_CONSOLE_GRPC_TARGET=127.0.0.1:50051
WORKER_CONSOLE_INSECURE=true
WORKER_ID=CHANGE_ME
WORKER_SECRET=CHANGE_ME

# These images must already exist in the internal registry before the worker starts.
WORKER_PYTHON_EXEC_DOCKER_IMAGE=boen-registry-vpc.cn-shenzhen.cr.aliyuncs.com/biel_client/onlyboxes-python:python3.12-bookworm-slim
WORKER_TERMINAL_EXEC_DOCKER_IMAGE=boen-registry-vpc.cn-shenzhen.cr.aliyuncs.com/biel_client/onlyboxes-runtime:0.7.1-lobehub

WORKER_HEARTBEAT_INTERVAL_SEC=5
WORKER_HEARTBEAT_JITTER_PCT=20
# Allows the bounded 10 MiB Masterino export fallback after base64 encoding.
WORKER_TERMINAL_OUTPUT_LIMIT_BYTES=16777216
